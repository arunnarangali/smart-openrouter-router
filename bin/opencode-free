#!/usr/bin/env python3
"""Run OpenCode with smart-openrouter-router.

Starts the router on a free local port, runs OpenCode with provider overrides,
and stops the router when OpenCode exits.
"""

from __future__ import annotations

import json
import os
import shutil
import signal
import socket
import subprocess
import sys
import time
from pathlib import Path
from urllib.error import URLError
from urllib.request import Request, urlopen


CONFIG_DIR = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "smart-openrouter-router"
CACHE_DIR = Path(os.environ.get("XDG_CACHE_HOME", Path.home() / ".cache")) / "smart-openrouter-router"
KEY_FILE = CONFIG_DIR / "api_key"
ACTIVE_FILE = CACHE_DIR / "active.json"
LOG_FILE = CACHE_DIR / "router.log"


def install_prefix() -> Path:
    return Path(__file__).resolve().parent.parent


SHARE_DIR = install_prefix() / "share" / "smart-openrouter-router"
ROUTER_SCRIPT = SHARE_DIR / "smart_router.py"


def eprint(message: str) -> None:
    sys.stderr.write(message + "\n")


def ensure_dirs() -> None:
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    CACHE_DIR.mkdir(parents=True, exist_ok=True)


def read_api_key() -> str:
    saved_key = KEY_FILE.read_text(encoding="utf-8").strip() if KEY_FILE.exists() else ""
    env_key = os.environ.get("OPENROUTER_API_KEY", "").strip()

    if saved_key and env_key and saved_key != env_key:
        eprint("Saved key and OPENROUTER_API_KEY differ. Using saved key from config.")

    if saved_key:
        return saved_key
    if env_key:
        return env_key
    return ""


def pick_free_port() -> int:
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as sock:
        sock.bind(("127.0.0.1", 0))
        return sock.getsockname()[1]


def wait_for_status(port: int, timeout: float = 6.0) -> bool:
    deadline = time.time() + timeout
    url = f"http://127.0.0.1:{port}/status"
    while time.time() < deadline:
        try:
            req = Request(url)
            with urlopen(req, timeout=1.0):
                return True
        except URLError:
            time.sleep(0.2)
    return False


def start_router(api_key: str, port: int) -> subprocess.Popen:
    env = os.environ.copy()
    env["OPENROUTER_API_KEY"] = api_key
    env["PROXY_PORT"] = str(port)
    env["SMART_ROUTER_LOG"] = str(LOG_FILE)

    if not ROUTER_SCRIPT.exists():
        fallback = Path.home() / "smart_router.py"
        if fallback.exists():
            return start_router_from_path(api_key, port, fallback)
        raise FileNotFoundError(f"Router script not found: {ROUTER_SCRIPT}")

    return start_router_from_path(api_key, port, ROUTER_SCRIPT)


def start_router_from_path(api_key: str, port: int, script_path: Path) -> subprocess.Popen:
    env = os.environ.copy()
    env["OPENROUTER_API_KEY"] = api_key
    env["PROXY_PORT"] = str(port)
    env["SMART_ROUTER_LOG"] = str(LOG_FILE)

    log_handle = LOG_FILE.open("a", encoding="utf-8")
    proc = subprocess.Popen(
        [sys.executable, str(script_path)],
        stdout=log_handle,
        stderr=subprocess.STDOUT,
        env=env,
    )
    return proc


def write_active(port: int, pid: int) -> None:
    payload = {
        "port": port,
        "pid": pid,
        "started_at": time.time(),
    }
    ACTIVE_FILE.write_text(json.dumps(payload), encoding="utf-8")


def stop_router(proc: subprocess.Popen) -> None:
    if proc.poll() is not None:
        return
    proc.terminate()
    try:
        proc.wait(timeout=3)
    except subprocess.TimeoutExpired:
        proc.kill()
        proc.wait(timeout=2)


def print_tail_log(lines: int = 40) -> None:
    if not LOG_FILE.exists():
        eprint("(router log not found)")
        return
    data = LOG_FILE.read_text(encoding="utf-8", errors="ignore").splitlines()
    tail = data[-lines:]
    eprint("\n--- Router log (tail) ---")
    for line in tail:
        eprint(line)
    eprint("--- end log ---\n")


def runtime_opencode_config(port: int, api_key: str) -> str:
    payload = {
        "$schema": "https://opencode.ai/config.json",
        "provider": {
            "smart-router": {
                "npm": "@ai-sdk/openai-compatible",
                "name": "Smart Router",
                "options": {
                    "baseURL": f"http://127.0.0.1:{port}/v1",
                    "apiKey": api_key,
                },
                "models": {
                    "build": {"name": "Smart Router Build"},
                    "plan": {"name": "Smart Router Plan"},
                },
            }
        },
        "model": "smart-router/build",
        "small_model": "smart-router/plan",
        "agent": {
            "build": {"model": "smart-router/build"},
            "plan": {"model": "smart-router/plan"},
        },
    }
    return json.dumps(payload)


def main() -> int:
    if not shutil.which("opencode"):
        eprint("OpenCode not found in PATH. Install it and try again.")
        return 1

    ensure_dirs()
    api_key = read_api_key()
    if not api_key:
        eprint("OpenRouter API key not found. Run: smart-router setup")
        return 1

    port = pick_free_port()
    try:
        proc = start_router(api_key, port)
    except FileNotFoundError as exc:
        eprint(str(exc))
        return 1

    try:
        if not wait_for_status(port):
            eprint("Router failed to start or respond.")
            print_tail_log()
            stop_router(proc)
            return 1

        write_active(port, proc.pid)

        env = os.environ.copy()
        env["OPENROUTER_API_KEY"] = api_key
        env["OPENCODE_CONFIG_CONTENT"] = runtime_opencode_config(port, api_key)

        def handle_signal(_signum, _frame):
            stop_router(proc)
            sys.exit(130)

        signal.signal(signal.SIGINT, handle_signal)
        signal.signal(signal.SIGTERM, handle_signal)

        result = subprocess.run(["opencode", *sys.argv[1:]], env=env)
        return result.returncode
    finally:
        stop_router(proc)
        if ACTIVE_FILE.exists():
            try:
                ACTIVE_FILE.unlink()
            except OSError:
                pass


if __name__ == "__main__":
    raise SystemExit(main())
