def default_config() -> dict:
    default_profile = {
        "preferred": [],
        "prefer_patterns": [],
        "avoid_patterns": ["audio", "music", "tts", "embedding"],
        "min_context": 8000,
    }
    profiles = {name: dict(default_profile) for name in SCENARIOS}
    profiles["coding_general"].update({"prefer_patterns": ["coder", "code", "qwen", "deepseek", "instruct"], "min_context": 16000})
    profiles["reasoning_general"].update({"prefer_patterns": ["reasoning", "think", "r1", "qwq", "qwen", "deepseek"], "min_context": 32000})
    profiles["writing_general"].update({"prefer_patterns": ["llama", "gemma", "mistral", "chat", "instruct"], "min_context": 8000})
    profiles["vision"].update({"prefer_patterns": ["vision", "multimodal", "image", "pixel"], "avoid_patterns": ["tiny", "3b", "4b", "flash"], "min_context": 4096})
    profiles["long_context"].update({"prefer_patterns": ["large", "128k", "200k", "context"], "avoid_patterns": ["tiny", "3b"], "min_context": 32000})
    profiles["fast"].update({"prefer_patterns": ["flash", "mini", "small", "3b", "4b", "7b", "8b"], "avoid_patterns": ["405b", "120b", "large"], "min_context": 4096})
    profiles["research_general"].update({"prefer_patterns": ["flash", "mini", "small", "fast"], "min_context": 4096})
    profiles["creative_general"].update({"prefer_patterns": ["creative", "story", "gemma", "llama"], "min_context": 8192})
    return {
        "config_version": 1,
        "updated_at": None,
        "source": "default",
        "policy": {"mode": "free-only", "allow_paid_fallback": False},
        "_notes": [
            "Generated by smart-router config refresh.",
            "Only OpenRouter free models are used.",
            "Preferred model IDs are bonuses, not hard requirements.",
            "Use smart-router config refresh to update preferred models.",
            "Cooldowns and stats can influence runtime final routing.",
        ],
        "profiles": profiles,
    }


def install_prefix() -> Path:
    return Path(__file__).resolve().parent.parent


def share_dir() -> Path:
    return install_prefix() / "share" / "smart-openrouter-router"


def version_file() -> Path:
    return share_dir() / "VERSION"


def eprint(message: str) -> None:
    sys.stderr.write(message + "\n")


def ensure_dirs() -> None:
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    CACHE_DIR.mkdir(parents=True, exist_ok=True)


def read_json_file(path: Path, fallback: dict) -> dict:
    if not path.exists():
        return dict(fallback)
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError:
        return dict(fallback)


def write_json_file(path: Path, payload: dict) -> None:
    ensure_dirs()
    path.write_text(json.dumps(payload, indent=2) + "\n", encoding="utf-8")


def read_api_key() -> str:
    env_key = os.environ.get("OPENROUTER_API_KEY", "").strip()
    if env_key:
        return env_key
    if KEY_FILE.exists():
        return KEY_FILE.read_text(encoding="utf-8").strip()
    return ""


def read_saved_api_key() -> str:
    if KEY_FILE.exists():
        return KEY_FILE.read_text(encoding="utf-8").strip()
    return ""


def write_api_key(key: str) -> None:
    ensure_dirs()
    KEY_FILE.write_text(key.strip() + "\n", encoding="utf-8")
    KEY_FILE.chmod(0o600)


def verify_key(key: str) -> bool:
    req = Request(OPENROUTER_MODELS_URL, headers={"Authorization": f"Bearer {key}"})
    try:
        with urlopen(req, timeout=10) as resp:
            data = json.loads(resp.read())
        return "data" in data
    except (HTTPError, URLError, json.JSONDecodeError):
        return False


def load_active() -> dict:
    return read_json_file(ACTIVE_FILE, {})


def request_json(port: int, path: str) -> dict:
    req = Request(f"http://127.0.0.1:{port}{path}")
    with urlopen(req, timeout=6) as resp:
        return json.loads(resp.read())


def installed_version() -> str:
    path = version_file()
    if not path.exists():
        return "unknown"
    value = path.read_text(encoding="utf-8").strip()
    return value or "unknown"


def latest_tag() -> str:
    req = Request(f"https://api.github.com/repos/{REPO}/releases/latest")
    with urlopen(req, timeout=10) as resp:
        data = json.loads(resp.read())
    tag = str(data.get("tag_name", "")).strip()
    if not tag:
        raise ValueError("Latest release tag not found")
    return tag


def run_upgrade(target: str, prefix: Path) -> int:
    if shutil.which("curl") is None or shutil.which("bash") is None:
        eprint("Upgrade requires curl and bash.")
        return 1
    env = os.environ.copy()
    env["SMART_ROUTER_VERSION"] = target
    env["SMART_ROUTER_PREFIX"] = str(prefix)
    command = f"curl -fsSL https://raw.githubusercontent.com/{REPO}/main/smart-router-install.sh | bash"
    return int(subprocess.run(["bash", "-lc", command], env=env).returncode)


def fetch_free_models(api_key: str) -> list[dict]:
    req = Request(
        OPENROUTER_MODELS_URL,
        headers={
            "Authorization": f"Bearer {api_key}",
            "HTTP-Referer": "https://github.com/smart-router",
            "X-Title": "SmartRouter",
        },
    )
    with urlopen(req, timeout=15) as resp:
        data = json.loads(resp.read())

    free: list[dict] = []
    for model in data.get("data", []):
        pricing = model.get("pricing", {})
        prompt_cost = float(pricing.get("prompt", "1") or "1")
        completion_cost = float(pricing.get("completion", "1") or "1")
        if prompt_cost != 0 or completion_cost != 0:
            continue

        architecture = model.get("architecture") or {}
        modality = str(architecture.get("modality") or "").lower()
        input_modalities = {str(item).lower() for item in architecture.get("input_modalities", [])}
        output_modalities = {str(item).lower() for item in architecture.get("output_modalities", [])}
        if input_modalities and "text" not in input_modalities:
            continue
        if output_modalities and "text" not in output_modalities:
            continue
        if modality and "text" not in modality:
            continue

        combined = " ".join(str(model.get(field) or "").lower() for field in ["id", "name", "description"])
        if any(term in combined for term in ["audio", "image", "video", "music", "lyria", "tts", "embedding"]):
            continue

        free.append(model)
    return free


def profile_score(model: dict, profile: dict, scenario: str) -> float:
    model_id = str(model.get("id") or "")
    combined = " ".join(
        [
            model_id.lower(),
            str(model.get("name") or "").lower(),
            str(model.get("description") or "").lower(),
        ]
    )
    ctx = int(model.get("context_length") or 0)
    score = 0.0

    preferred = [str(x) for x in profile.get("preferred", [])]
    if model_id in preferred:
        idx = preferred.index(model_id)
        score += max(20, 60 - idx * 10)

    for pattern in profile.get("prefer_patterns", []):
        if str(pattern).lower() in combined:
            score += 8

    for pattern in profile.get("avoid_patterns", []):
        if str(pattern).lower() in combined:
            score -= 20

    min_context = int(profile.get("min_context") or 0)
    if min_context and ctx < min_context:
        score -= 25
    elif ctx >= 128000:
        score += 12
    elif ctx >= 32000:
        score += 7
    elif ctx >= 8000:
        score += 3

    if scenario.startswith("coding_"):
        if "coder" in combined:
            score += 20
        if "code" in combined:
            score += 12
    elif scenario.startswith("reasoning_"):
        if "reason" in combined or "think" in combined:
            score += 18
    elif scenario.startswith("writing_"):
        if "chat" in combined or "instruct" in combined:
            score += 10
    elif scenario.startswith("research_"):
        if "search" in combined or "flash" in combined:
            score += 12
    elif scenario.startswith("creative_"):
        if "creative" in combined or "story" in combined:
            score += 12
    elif scenario == "fast":
        if any(x in combined for x in ["flash", "mini", "small", "3b", "4b", "7b", "8b"]):
            score += 22

    return score


def _specificity(scenario: str) -> int:
    return 0 if scenario.endswith("_general") else 1


def analyze_prompt_text(prompt: str) -> dict:
    text = str(prompt or "").lower()
    scores = {scenario: 0 for scenario in SCENARIOS}
    for scenario, keywords in SCENARIO_KEYWORDS.items():
        for keyword, weight in keywords.items():
            if keyword in text:
                scores[scenario] += int(weight)

    detected = max(SCENARIOS, key=lambda s: (scores[s], _specificity(s)))
    if scores[detected] <= 0:
        detected = "reasoning_general"

    positive = sorted([(name, value) for name, value in scores.items() if value > 0], key=lambda item: item[1], reverse=True)
    top_score = positive[0][1] if positive else 0
    total = sum(value for _name, value in positive)
    confidence = round((top_score / total), 3) if total > 0 else 0.0
    return {
        "detected_scenario": detected,
        "scenario_confidence": confidence,
        "top_scenarios": positive,
        "scenario_scores": scores,
    }


def rank_for_scenario(models: list[dict], profile: dict, scenario: str, top_n: int = 5) -> list[str]:
    ranked = sorted(models, key=lambda m: profile_score(m, profile, scenario), reverse=True)
    return [str(m.get("id")) for m in ranked if m.get("id")][:top_n]


def load_config() -> dict:
    base = default_config()
    current = read_json_file(CONFIG_FILE, base)
    if not isinstance(current, dict):
        return base
    merged = base
    merged.update({k: v for k, v in current.items() if k != "profiles"})
    profiles = current.get("profiles") if isinstance(current.get("profiles"), dict) else {}
    for name, default_profile in base["profiles"].items():
        custom = profiles.get(name) if isinstance(profiles, dict) else {}
        if isinstance(custom, dict):
            prof = dict(default_profile)
            prof.update(custom)
            merged["profiles"][name] = prof
    return merged


def save_config(cfg: dict) -> None:
    write_json_file(CONFIG_FILE, cfg)


def cmd_setup(args: argparse.Namespace) -> int:
    ensure_dirs()
    current_key = read_saved_api_key()
    eprint("Setting up OpenRouter API key...")
    if current_key:
        eprint("Existing saved key found. It will be replaced only after the new key is verified.")
    else:
        eprint("No saved key found. A new key will be stored after verification.")
    key = ""
    if args.from_env:
        key = os.environ.get("OPENROUTER_API_KEY", "").strip()
        if not key:
            eprint("OPENROUTER_API_KEY is not set.")
            return 1
        eprint("Reading replacement key from OPENROUTER_API_KEY environment variable.")
    else:
        try:
            if args.visible:
                eprint("Enter new OpenRouter API key (input visible):")
                key = input("")
            else:
                eprint("Enter new OpenRouter API key (input hidden; paste and press Enter):")
                key = __import__("getpass").getpass("")
        except KeyboardInterrupt:
            eprint("Setup cancelled.")
            return 130

    key = key.strip()
    if not key:
        eprint("No key provided.")
        return 1

    eprint("Verifying new key with OpenRouter...")
    if not verify_key(key):
        eprint("Verification failed. Old saved key was not replaced.")
        return 1

    write_api_key(key)
    if current_key:
        eprint("New key verified. Old saved key replaced successfully.")
    else:
        eprint("New key verified and saved successfully.")
    return 0


def cmd_status(_args: argparse.Namespace) -> int:
    active = load_active()
    port = active.get("port")
    if not port:
        eprint("Router not running. Start with: claude-free")
        return 1
    try:
        print(json.dumps(request_json(int(port), "/status"), indent=2))
        return 0
    except (URLError, HTTPError, json.JSONDecodeError):
        eprint("Router not responding. Try: claude-free")
        return 1


def cmd_last(_args: argparse.Namespace) -> int:
    active = load_active()
    port = active.get("port")
    if not port:
        eprint("Router not running. Start with: claude-free")
        return 1
    try:
        print(json.dumps(request_json(int(port), "/last"), indent=2))
        return 0
    except (URLError, HTTPError, json.JSONDecodeError):
        eprint("Router not responding. Try: claude-free")
        return 1


def cmd_version(_args: argparse.Namespace) -> int:
    print(installed_version())
    return 0


def cmd_upgrade(args: argparse.Namespace) -> int:
    if args.check and args.version:
        eprint("Use either --check or --version, not both.")
        return 1
    current = installed_version()
    try:
        latest = latest_tag()
    except (HTTPError, URLError, json.JSONDecodeError, ValueError) as exc:
        eprint(f"Failed to fetch latest release: {exc}")
        return 1

    if args.check:
        print(f"Installed: {current}, Latest: {latest}")
        return 0 if current == latest else 2

    target = args.version.strip() if args.version else latest
    eprint(f"Upgrading {current} -> {target}")
    return run_upgrade(target, install_prefix())


def stop_router() -> None:
    ensure_dirs()
    active = load_active()
    pid = active.get("pid")
    if pid:
        try:
            os.kill(int(pid), signal.SIGTERM)
            time.sleep(0.5)
        except OSError:
            pass


def remove_path(path: Path) -> None:
    if not path.exists():
        return
    try:
        if path.is_dir():
            shutil.rmtree(path)
        else:
            path.unlink()
    except OSError as exc:
        eprint(f"Failed to remove {path}: {exc}")


def uninstall_targets(prefix: Path) -> list[Path]:
    bin_dir = prefix / "bin"
    share_dir = prefix / "share" / "smart-openrouter-router"
    return [
        bin_dir / "smart-router",
        bin_dir / "claude-free",
        bin_dir / "opencode-free",
        share_dir,
        CONFIG_DIR,
        CACHE_DIR,
    ]


def confirm_uninstall(targets: list[Path], assume_yes: bool) -> bool:
    eprint("This will remove the following paths:")
    for path in targets:
        eprint(f"  - {path}")
    if assume_yes:
        return True
    if not sys.stdin.isatty():
        eprint("Refusing to uninstall without confirmation (non-interactive shell). Use --yes.")
        return False
    eprint("This action is permanent.")
    answer = input("Continue? [y/N] ").strip().lower()
    return answer in {"y", "yes"}


def cmd_uninstall(args: argparse.Namespace) -> int:
    prefix = install_prefix()
    marker = prefix / "share" / "smart-openrouter-router" / "VERSION"
    if not marker.exists():
        eprint("Install marker not found. Run the installed smart-router from your PATH.")
        return 1

    stop_router()
    targets = uninstall_targets(prefix)
    if not confirm_uninstall(targets, args.yes):
        eprint("Uninstall cancelled.")
        return 1
    for path in targets:
        remove_path(path)
    eprint("Uninstall complete.")
    return 0


def cmd_reset(args: argparse.Namespace) -> int:
    if args.all:
        uninstall_args = argparse.Namespace(yes=True)
        return cmd_uninstall(uninstall_args)

    stop_router()
    for path in [ACTIVE_FILE, LOG_FILE, COOLDOWNS_FILE, STATS_FILE]:
        if path.exists():
            try:
                path.unlink()
            except OSError:
                pass

    eprint("Reset complete. Your API key is preserved.")
    return 0


def cmd_config_path(_args: argparse.Namespace) -> int:
    print(str(CONFIG_FILE))
    return 0


def cmd_config_view(_args: argparse.Namespace) -> int:
    if not CONFIG_FILE.exists():
        eprint("Config not found. Run: smart-router config refresh")
        return 1
    print(CONFIG_FILE.read_text(encoding="utf-8"))
    return 0


def cmd_config_explain(_args: argparse.Namespace) -> int:
    print(
        "\n".join(
            [
                f"Config path: {CONFIG_FILE}",
                "- free-only routing is enforced before ranking",
                "- preferred model IDs are bonuses, not hard requirements",
                "- prefer_patterns and avoid_patterns shape scenario ranking",
                "- cooldowns and stats can alter runtime final model choice",
                "- refresh config whenever OpenRouter model availability changes",
                "- use smart-router models to view current best live free models",
            ]
        )
    )
    return 0


def cmd_models(args: argparse.Namespace) -> int:
    key = read_api_key()
    if not key:
        eprint("OpenRouter API key not found. Run: smart-router setup")
        return 1

    try:
        free_models = fetch_free_models(key)
    except (HTTPError, URLError, json.JSONDecodeError) as exc:
        eprint(f"Failed to fetch OpenRouter models: {exc}")
        return 1

    cfg = load_config()
    profiles = cfg.get("profiles", {})
    result = {"source": "openrouter-live-free-models", "policy": "free-only", "scenarios": {}}

    for scenario in SCENARIOS:
        profile = profiles.get(scenario, {})
        result["scenarios"][scenario] = rank_for_scenario(free_models, profile, scenario, top_n=args.top)

    if args.json:
        print(json.dumps(result, indent=2))
        return 0

    print("Current best free OpenRouter models")
    for scenario in SCENARIOS:
        print(f"\n{scenario}:")
        for idx, model_id in enumerate(result["scenarios"].get(scenario, []), start=1):
            print(f"  {idx}. {model_id}")
    print("\nNote: Runtime may still skip models due to cooldowns, stats, quota, or tool support.")
    return 0


def cmd_scenario(args: argparse.Namespace) -> int:
    result = analyze_prompt_text(args.prompt)
    top_n = max(1, int(args.top))
    result["top_scenarios"] = result["top_scenarios"][:top_n]
    print(json.dumps(result, indent=2))
    return 0


def cmd_config_reset(_args: argparse.Namespace) -> int:
    cfg = default_config()
    cfg["updated_at"] = datetime.now(timezone.utc).isoformat()
    cfg["source"] = "reset-defaults"
    save_config(cfg)
    print(f"Reset config: {CONFIG_FILE}")
    return 0


def cmd_config_refresh(_args: argparse.Namespace) -> int:
    key = read_api_key()
    if not key:
        eprint("OpenRouter API key not found. Run: smart-router setup")
        return 1

    try:
        free_models = fetch_free_models(key)
    except (HTTPError, URLError, json.JSONDecodeError) as exc:
        eprint(f"Failed to fetch OpenRouter models: {exc}")
        return 1

    cfg = load_config()
    profiles = cfg.get("profiles", {})
    for scenario in SCENARIOS:
        profile = profiles.get(scenario, {})
        preferred = rank_for_scenario(free_models, profile, scenario, top_n=5)
        profile["preferred"] = preferred
        profiles[scenario] = profile

    cfg["profiles"] = profiles
    cfg["policy"] = {"mode": "free-only", "allow_paid_fallback": False}
    cfg["updated_at"] = datetime.now(timezone.utc).isoformat()
    cfg["source"] = "openrouter-live-free-models"
    save_config(cfg)

    print(f"Updated config: {CONFIG_FILE}")
    for scenario in SCENARIOS:
        print(f"\n{scenario}:")
        for idx, model_id in enumerate(cfg["profiles"][scenario].get("preferred", [])[:3], start=1):
            print(f"  {idx}. {model_id}")
    return 0


def cmd_cooldowns(_args: argparse.Namespace) -> int:
    data = read_json_file(COOLDOWNS_FILE, {"models": {}, "providers": {}})
    print(json.dumps(data, indent=2))
    return 0


def cmd_cooldowns_clear(_args: argparse.Namespace) -> int:
    if COOLDOWNS_FILE.exists():
        COOLDOWNS_FILE.unlink()
    print("Cooldowns cleared.")
    return 0


def cmd_stats(_args: argparse.Namespace) -> int:
    data = read_json_file(STATS_FILE, {"models": {}, "scenarios": {}})
    data.setdefault("models", {})
    data.setdefault("scenarios", {})
    print(json.dumps(data, indent=2))
    return 0


def cmd_stats_reset(_args: argparse.Namespace) -> int:
    if STATS_FILE.exists():
        STATS_FILE.unlink()
    print("Stats reset.")
    return 0


def cmd_logs(args: argparse.Namespace) -> int:
    if args.path:
        print(str(LOG_FILE))
        return 0
    if not LOG_FILE.exists():
        eprint("Router log not found.")
        return 1
    data = LOG_FILE.read_text(encoding="utf-8", errors="ignore").splitlines()
    lines = max(1, int(args.lines))
    for line in data[-lines:]:
        print(line)
    return 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="smart-router",
        description="Smart Router helper CLI",
        epilog=HELP_EPILOG,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="command", required=True)

    setup = sub.add_parser("setup", help="Store and verify OpenRouter API key", epilog=HELP_EPILOG, formatter_class=argparse.RawDescriptionHelpFormatter)
    setup_group = setup.add_mutually_exclusive_group()
    setup_group.add_argument("--from-env", action="store_true", help="Read OPENROUTER_API_KEY from env")
    setup_group.add_argument("--visible", action="store_true", help="Show input while typing")
    setup.set_defaults(func=cmd_setup)

    sub.add_parser("status", help="Show router status", epilog=HELP_EPILOG, formatter_class=argparse.RawDescriptionHelpFormatter).set_defaults(func=cmd_status)
    sub.add_parser("last", help="Show last routed request", epilog=HELP_EPILOG, formatter_class=argparse.RawDescriptionHelpFormatter).set_defaults(func=cmd_last)
    models = sub.add_parser("models", help="Show current best free models by scenario", epilog=HELP_EPILOG, formatter_class=argparse.RawDescriptionHelpFormatter)
    models.add_argument("--json", action="store_true", help="Output JSON")
    models.add_argument("--top", type=int, default=3, help="Number of models per scenario")
    models.set_defaults(func=cmd_models)
    scenario = sub.add_parser("scenario", help="Analyze prompt scenario detection", epilog=HELP_EPILOG, formatter_class=argparse.RawDescriptionHelpFormatter)
    scenario.add_argument("prompt", help="Prompt text to analyze")
    scenario.add_argument("--top", type=int, default=5, help="Show top N scenario scores")
    scenario.set_defaults(func=cmd_scenario)
    sub.add_parser("version", help="Show installed version", epilog=HELP_EPILOG, formatter_class=argparse.RawDescriptionHelpFormatter).set_defaults(func=cmd_version)

    upgrade = sub.add_parser("upgrade", help="Upgrade to latest or specific tag", epilog=HELP_EPILOG, formatter_class=argparse.RawDescriptionHelpFormatter)
    upgrade.add_argument("--check", action="store_true", help="Check installed vs latest")
    upgrade.add_argument("--version", default="", help="Install a specific tag (example: v0.3.0)")
    upgrade.set_defaults(func=cmd_upgrade)

    reset = sub.add_parser("reset", help="Reset runtime state", epilog=HELP_EPILOG, formatter_class=argparse.RawDescriptionHelpFormatter)
    reset.add_argument("--all", action="store_true", help="Remove saved key/config and uninstall commands")
    reset.set_defaults(func=cmd_reset)

    uninstall = sub.add_parser(
        "uninstall",
        help="Remove installed commands and all local state",
        epilog=HELP_EPILOG,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    uninstall.add_argument("--yes", action="store_true", help="Skip confirmation prompt")
    uninstall.set_defaults(func=cmd_uninstall)

    config = sub.add_parser("config", help="Manage router config", epilog=HELP_EPILOG, formatter_class=argparse.RawDescriptionHelpFormatter)
    cfg_sub = config.add_subparsers(dest="config_cmd", required=True)
    cfg_sub.add_parser("path", help="Show config path").set_defaults(func=cmd_config_path)
    cfg_sub.add_parser("view", help="View current config").set_defaults(func=cmd_config_view)
    cfg_sub.add_parser("explain", help="Explain config behavior").set_defaults(func=cmd_config_explain)
    cfg_sub.add_parser("reset", help="Reset config to defaults").set_defaults(func=cmd_config_reset)
    cfg_sub.add_parser("refresh", help="Refresh best free models in config").set_defaults(func=cmd_config_refresh)

    cool = sub.add_parser("cooldowns", help="Show active cooldowns", epilog=HELP_EPILOG, formatter_class=argparse.RawDescriptionHelpFormatter)
    cool_sub = cool.add_subparsers(dest="cool_cmd")
    cool.set_defaults(func=cmd_cooldowns)
    cool_sub.add_parser("clear", help="Clear all cooldowns").set_defaults(func=cmd_cooldowns_clear)

    stats = sub.add_parser("stats", help="Show model stats", epilog=HELP_EPILOG, formatter_class=argparse.RawDescriptionHelpFormatter)
    stats_sub = stats.add_subparsers(dest="stats_cmd")
    stats.set_defaults(func=cmd_stats)
    stats_sub.add_parser("reset", help="Reset model stats").set_defaults(func=cmd_stats_reset)

    logs = sub.add_parser("logs", help="Show router logs", epilog=HELP_EPILOG, formatter_class=argparse.RawDescriptionHelpFormatter)
    logs.add_argument("--lines", type=int, default=80, help="Show last N lines")
    logs.add_argument("--path", action="store_true", help="Print log file path")
    logs.set_defaults(func=cmd_logs)

    return parser


def main() -> int:
    parser = build_parser()
    args = parser.parse_args()
    return int(args.func(args))


if __name__ == "__main__":
    raise SystemExit(main())
